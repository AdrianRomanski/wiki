{
  "name": "examples",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/wiki/examples/src",
  "projectType": "library",
  "tags": ["examples"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/wiki/examples",
        "main": "libs/wiki/examples/src/index.ts",
        "tsConfig": "libs/wiki/examples/tsconfig.lib.json",
        "assets": ["libs/wiki/examples/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config libs/wiki/examples/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "implicitDependencies": [
    "core",
    "infrastructure-filesystem",
    "infrastructure-markdown",
    "infrastructure-frontmatter",
    "application-query",
    "application-workflow",
    "application-cross-reference"
  ]
}
