{
  "name": "@wiki-graph/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nx": "npx nx",
    "start:graph": "npx nx run wiki-graph:serve --port=4300",
    "build:mcp": "npx nx run wiki-mcp-server:build",
    "build:manifest": "npx nx run wiki-cli:generate-manifest",
    "build:wiki-index": "npx nx run wiki-cli:generate-index",
    "examples:setup": "echo 'Run: npx nx test examples' && echo 'Setup examples are demonstrated in generate-entity-page tests'",
    "examples:generate": "npx nx test examples --testNamePattern=\"generate\" --run",
    "examples:query": "npx nx test examples --testNamePattern=\"query|search\" --run",
    "examples:maintenance": "npx nx test examples --testNamePattern=\"maintenance\" --run",
    "examples:all": "npx nx test examples --run",
    "init:frontend-libs": "node libs/wiki/examples/src/scripts/init-frontend-libraries.mjs",
    "init:backend-libs": "node libs/wiki/examples/src/scripts/init-backend-libraries.mjs",
    "init:testing-libs": "node libs/wiki/examples/src/scripts/init-testing-libraries.mjs",
    "init:articles-blog": "node libs/wiki/examples/src/scripts/init-blog-articles.mjs",
    "init:articles-docs": "node libs/wiki/examples/src/scripts/init-documentation-articles.mjs",
    "init:close-concepts": "node libs/wiki/examples/src/scripts/init-close-concepts.mjs",
    "init:far-concepts": "node libs/wiki/examples/src/scripts/init-far-concepts.mjs",
    "init:cross-domain": "node libs/wiki/examples/src/scripts/init-cross-domain.mjs",
    "init:all": "npm run init:frontend-libs && npm run init:backend-libs && npm run init:testing-libs && npm run init:articles-blog && npm run init:articles-docs && npm run init:close-concepts && npm run init:far-concepts && npm run init:cross-domain",
    "init:clean": "rm -f wiki/entities/*.md wiki/concepts/*.md wiki/sources/*.md",
    "validate:tags": "npx nx run wiki-cli:validate-tags",
    "init:wiki": "npx nx run wiki-cli:init"
  },
  "private": true,
  "dependencies": {
    "@angular/aria": "^21.2.10",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "d3": "^7.9.0",
    "gray-matter": "^4.0.3",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.8.0",
    "@fast-check/vitest": "^0.4.1",
    "@nrwl/storybook": "^19.8.4",
    "@nx/angular": "22.7.1",
    "@nx/devkit": "22.7.1",
    "@nx/esbuild": "^22.7.1",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/playwright": "22.7.1",
    "@nx/storybook": "22.7.1",
    "@nx/web": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.2.0",
    "@storybook/angular": "^10.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "4.1.5",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "fast-check": "^4.7.0",
    "glob": "^13.0.6",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "~21.2.0",
    "nx": "22.7.1",
    "postcss": "^8.4.5",
    "prettier": "~3.6.2",
    "simple-git": "^3.36.0",
    "storybook": "^10.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.8"
  }
}
